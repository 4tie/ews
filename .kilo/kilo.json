{
  "$schema": "https://app.kilo.ai/config.json",
  "mcp": {
    "memory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "n8n-mcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "n8n-mcp@2.12.2"
      ],
      "environment": {
        "MCP_MODE": "stdio",
        "LOG_LEVEL": "error",
        "DISABLE_CONSOLE_OUTPUT": "true"
      }
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@0.0.38"
      ]
    },
    "sequentialthinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    }
  },
    "instructions": [
      "AGENTS.md",
      ".kilo/rules/01-repo-audit.md",
      ".kilo/rules/02-implementation.md",
      ".kilo/rules/03-ai-routing.md",
      ".kilo/rules/04-no-duplication.md"
    ]
}